{
  "entities": {
    "settings": {
      "title": "Site Settings",
      "description": "Global site settings including maintenance mode",
      "type": "object",
      "properties": {
        "maintenanceMode": { "type": "boolean", "description": "Is the site in maintenance mode?" },
        "clubName": { "type": "string" },
        "logoUrl": { "type": "string" }
      },
      "required": ["maintenanceMode"]
    },
    "news": {
      "title": "News",
      "description": "Club news and announcements",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "category": { "type": "string" },
        "isHidden": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["title", "date", "isHidden"]
    },
    "branches": {
      "title": "Branches",
      "description": "Sports branches like Basketball, Volleyball, etc.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "coachName": { "type": "string" },
        "coachContact": { "type": "string" },
        "isHidden": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["name", "isHidden"]
    },
    "teams": {
      "title": "Teams",
      "description": "Teams within branches (e.g., U-11 Basketball)",
      "type": "object",
      "properties": {
        "branchId": { "type": "string" },
        "name": { "type": "string" },
        "coachName": { "type": "string" },
        "isHidden": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["branchId", "name", "isHidden"]
    },
    "players": {
      "title": "Players",
      "description": "Players in teams",
      "type": "object",
      "properties": {
        "teamId": { "type": "string" },
        "name": { "type": "string" },
        "number": { "type": "string" },
        "position": { "type": "string" },
        "isHidden": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["teamId", "name", "isHidden"]
    },
    "staff": {
      "title": "Staff",
      "description": "Club personnel and board members",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "image": { "type": "string" },
        "isHidden": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["name", "role", "isHidden"]
    },
    "gallery": {
      "title": "Gallery",
      "description": "Club photos and albums",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "isHidden": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["imageUrl", "isHidden"]
    },
    "matches": {
      "title": "Matches",
      "description": "Upcoming and past matches",
      "type": "object",
      "properties": {
        "teamId": { "type": "string", "description": "The ID of the local team involved" },
        "homeTeam": { "type": "string" },
        "homeLogo": { "type": "string", "description": "Optional logo URL for the home team" },
        "awayTeam": { "type": "string" },
        "awayLogo": { "type": "string", "description": "Optional logo URL for the away team" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "isHidden": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["teamId", "homeTeam", "awayTeam", "date", "isHidden"]
    },
    "navigation": {
      "title": "Navigation",
      "description": "Dynamic site navigation menu items",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "path": { "type": "string" },
        "order": { "type": "number" },
        "isHidden": { "type": "boolean" },
        "isDropdown": { "type": "boolean" },
        "dropdownType": { "type": "string", "enum": ["static", "branches", "teams", "fixtures"] }
      },
      "required": ["title", "path", "order", "isHidden"]
    }
  },
  "firestore": {
    "/settings/global": { "schema": "settings", "description": "Global settings document" },
    "/news/{newsId}": { "schema": "news", "description": "News articles" },
    "/branches/{branchId}": { "schema": "branches", "description": "Sports branches" },
    "/teams/{teamId}": { "schema": "teams", "description": "Teams" },
    "/players/{playerId}": { "schema": "players", "description": "Players" },
    "/staff/{staffId}": { "schema": "staff", "description": "Club staff" },
    "/gallery/{photoId}": { "schema": "gallery", "description": "Gallery photos" },
    "/matches/{matchId}": { "schema": "matches", "description": "Matches" },
    "/navigation/{navId}": { "schema": "navigation", "description": "Navigation menu items" }
  }
}
