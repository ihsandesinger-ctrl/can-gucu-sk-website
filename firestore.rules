// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: settings
// Document ID: global
// Fields:
//   - maintenanceMode: boolean (required) - Is the site in maintenance mode?
//   - clubName: string (optional)
//   - logoUrl: string (optional)
//
// Collection: news
// Document ID: newsId (auto-generated)
// Fields:
//   - title: string (required)
//   - summary: string (optional)
//   - content: string (optional)
//   - image: string (optional)
//   - date: string (required, format: date)
//   - category: string (optional)
//   - isHidden: boolean (required)
//
// Collection: branches
// Document ID: branchId (auto-generated)
// Fields:
//   - name: string (required)
//   - description: string (optional)
//   - coachName: string (optional)
//   - coachContact: string (optional)
//   - isHidden: boolean (required)
//
// Collection: teams
// Document ID: teamId (auto-generated)
// Fields:
//   - branchId: string (required)
//   - name: string (required)
//   - coachName: string (optional)
//   - isHidden: boolean (required)
//
// Collection: players
// Document ID: playerId (auto-generated)
// Fields:
//   - teamId: string (required)
//   - name: string (required)
//   - number: string (optional)
//   - position: string (optional)
//   - isHidden: boolean (required)
//
// Collection: matches
// Document ID: matchId (auto-generated)
// Fields:
//   - homeTeam: string (required)
//   - awayTeam: string (required)
//   - date: string (required)
//   - time: string (optional)
//   - location: string (optional)
//   - category: string (optional)
//   - isHidden: boolean (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "ihsandurgut1@gmail.com"));
    }

    function isHidden(data) {
      return data.isHidden == true;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Settings
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // News
    match /news/{newsId} {
      allow read: if !isHidden(resource.data) || isAdmin();
      allow write: if isAdmin();
    }

    // Branches
    match /branches/{branchId} {
      allow read: if !isHidden(resource.data) || isAdmin();
      allow write: if isAdmin();
    }

    // Teams
    match /teams/{teamId} {
      allow read: if !isHidden(resource.data) || isAdmin();
      allow write: if isAdmin();
    }

    // Players
    match /players/{playerId} {
      allow read: if !isHidden(resource.data) || isAdmin();
      allow write: if isAdmin();
    }

    // Staff
    match /staff/{staffId} {
      allow read: if !isHidden(resource.data) || isAdmin();
      allow write: if isAdmin();
    }

    // Gallery
    match /gallery/{photoId} {
      allow read: if !isHidden(resource.data) || isAdmin();
      allow write: if isAdmin();
    }

    // Matches
    match /matches/{matchId} {
      allow read: if !isHidden(resource.data) || isAdmin();
      allow write: if isAdmin();
    }

    // Navigation
    match /navigation/{navId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users (for role management)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
